# ==========================================
# [DEBUG/PARK-US] 아두이노 시리얼 데이터 일괄 읽기 (조향각 및 초음파)
# ==========================================
def read_serial_data(ser, last_angle, last_us):
    """
    아두이노 시리얼 버퍼에서 들어오는 모든 라인을 소비하며 조향각과 초음파 데이터를 일괄 업데이트.
    readline() 경쟁 유실 문제를 해결합니다.
    """
    if ser is None or not ser.is_open:
        return last_angle, last_us
    latest_angle = last_angle
    latest_us = dict(last_us)
    try:
        while ser.in_waiting > 0:
            line = ser.readline().decode('utf-8', errors='ignore').strip()
            if not line:
                continue
            # 1. 실제 조향각 응답 처리
            if "Cur Ang:" in line:
                try:
                    latest_angle = int(line.split("Cur Ang:")[1].strip())
                except ValueError:
                    pass
            # 2. 초음파 거리 응답 처리 (US: RF=120 RR=118 CL=45 CR=200 형식)
            elif line.startswith("US:"):
                try:
                    parts = line[3:].strip().split()
                    parsed = {}
                    for p in parts:
                        key, val = p.split('=')
                        val = int(val)
                        parsed[key] = None if val < 0 else val
                    latest_us.update(parsed)
                except (ValueError, IndexError):
                    pass
    except Exception:
        pass
    return latest_angle, latest_us


# ==========================================
# [PARK-US] 초음파 센서 수평 보정 조향각 연산 함수
# ==========================================
def get_parallel_steer(us_readings, config):
    """
    우측 앞(RF)과 뒤(RR) 초음파 센서 거리 편차를 비례 제어(P-제어)하여
    수평을 맞추는 최적의 전진 조향각을 도출하고 clamp 제한합니다.
    """
    rf = us_readings.get('RF')
    rr = us_readings.get('RR')
    if rf is None or rr is None:
        return config.STEER_CENTER
    diff = rf - rr
    # RF > RR (앞이 멂): 바퀴를 우측으로 꺾어 벽에 접근시킴 -> 각도 증가
    # RF < RR (앞이 가까움): 바퀴를 좌측으로 꺾어 벽에서 벌림 -> 각도 감소
    steer_offset = config.PARALLEL_KP * diff
    target_steer = config.STEER_CENTER + steer_offset
    target_steer = max(config.STEER_MIN, min(target_steer, config.STEER_MAX))
    return int(target_steer)


