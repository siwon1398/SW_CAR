# [PARK] 비동기 라이다 리더 (주행코드의 LidarStream 구조 재사용)
# ==========================================
class LidarStream:
    def __init__(self, lidar_lib, port):
        self.lidar_lib = lidar_lib
        self.port = port
        self.lidar = None
        self.current_scan = None
        self.started = False
        self.read_lock = threading.Lock()
        self.thread = None

    def start(self):
        if self.started:
            return self
        try:
            self.lidar = self.lidar_lib(self.port)
            self.lidar.init()
            self.lidar.getState()
            self.started = True
            self.thread = threading.Thread(target=self.update, args=())
            self.thread.daemon = True
            self.thread.start()
            print(f"라이다 스레드 시작. 포트: {self.port}")
        except Exception as e:
            print(f"라이다 초기화 에러: {e}")
            self.started = False
        return self

    def update(self):
        try:
            for scan in self.lidar.scanning():
                if not self.started:
                    break
                with self.read_lock:
                    self.current_scan = scan.copy()
                time.sleep(0.02)
        except Exception as e:
            print(f"라이다 수집 오류: {e}")
            self.started = False

    def read(self):
        with self.read_lock:
            return self.current_scan

    def release(self):
        self.started = False
        if self.thread and self.thread.is_alive():
            self.thread.join()
        if self.lidar is not None:
            try:
                self.lidar.stop()
                print("라이다 종료 완료.")
            except Exception as e:
                print(f"라이다 중지 에러: {e}")


