# [DEBUG] 상태 전환 판단: 단계별 수동 진행 모드 지원
# ==========================================
def should_advance(state_start, now, duration, key, step_label, config):
    """
    DEBUG_STEP_MODE=True  → 'n' 키를 눌러야 다음 상태로 전환. 누른 시점의
                             경과 시간을 출력해 DURATION 값 확정에 사용.
    DEBUG_STEP_MODE=False → 기존처럼 duration(초)이 지나면 자동 전환.
    """
    if config.DEBUG_STEP_MODE:
        if key == ord('n'):
            elapsed = now - state_start
            print(f"[DEBUG-STEP] '{step_label}' 유지 시간: {elapsed:.2f}s "
                  f"→ 이 값을 해당 DURATION으로 넣으면 됩니다.")
            return True
        return False
    else:
        return (now - state_start) >= duration


def main():
    arduino = fl.libARDUINO()
    lidar_lib = fl.libLIDAR

    ser = None
    lidar_stream = None

    try:
        print("아두이노 연결 시도...")
        try:
            ser = arduino.init(Config.ARDUINO_PORT, Config.BAUD_RATE)
        except Exception as e:
            print(f"[DEBUG] 아두이노 연결 실패: {e}")
            print_available_ports()
            raise

        print("라이다 스트림 시작...")
        lidar_stream = LidarStream(lidar_lib, port=Config.LIDAR_PORT)
        lidar_stream.start()
        if not lidar_stream.started:
            print("[DEBUG] 라이다 연결 실패로 보입니다.")
            print_available_ports()

        # 상태 표시용 창 (키 입력 수신에도 필요)
        canvas = np.zeros((250, 560, 3), dtype=np.uint8)
        cv2.namedWindow('Parking Status')

        # --- 상태 머신 변수 ---
        state = 'IDLE'          # 현재 상태
        state_start = 0.0       # 현재 상태 진입 시각
        mission_start = 0.0     # 미션 시작 시각 (4분 제한 체크, 일시정지와 무관하게 실제 시간 그대로 흐름)
        occ_streak = 0          # 우측 '있음' 연속 프레임 수
        empty_streak = 0        # 우측 '없음' 연속 프레임 수
        seen_first_car = False  # 첫 번째 주차 차량을 본 적 있는지

        # 🌟 [FIX] 원본 주행코드의 is_driving 토글 컨벤션과 동일하게 맞춤
        is_driving = False      # s로 토글: True면 상태머신 진행, False면 정지(S) 유지
        pause_started_at = None # 일시정지에 들어간 시각 (재개 시 state_start 보정용)
        current_angle_actual = None  # [DEBUG] 아두이노가 보내주는 실제 조향각 (아직 못 받으면 None)
        us_readings = {'RF': None, 'RR': None, 'CL': None, 'CR': None}  # [PARK-US] 초음파 4개 최신값(cm)
        adjust_count = 0        # [PARK-US] 삐딱함 교정을 위한 수정 기동 횟수를 누적하는 카운터

        print("=======================================")
        print("주차 미션 대기 모드. [s] 시작/정지 토글 / [q] 종료")
        print("상태 흐름: SCAN_FIRST → SCAN_GAP → ALIGN_FWD → LEFT_FWD")
        print("        → REV_RIGHT_PREP → REV_RIGHT → REV_STRAIGHT → PARKED")
        print("        → EXIT_FWD_PREP → EXIT_TURN → EXIT_STRAIGHT → DONE")
        print("=======================================")

        while True:
            now = time.time()
            key = cv2.waitKey(30) & 0xFF  # [DEBUG] 상단으로 이동: 이번 이터레이션의 상태 판단에도 사용

            # [DEBUG/PARK-US] 아두이노 조향각 및 초음파 데이터 일괄 읽기 (논블로킹)
            current_angle_actual, us_readings = read_serial_data(ser, current_angle_actual, us_readings)

            # --- 라이다 우측면 판정 ---
            occupied, n_pts, closest_angle, closest_dist, right_pts = False, 0, None, None, None
            scan = lidar_stream.read()
            if scan is not None:
                try:
                    occupied, n_pts, closest_angle, closest_dist, right_pts = right_side_occupied(
                        lidar_stream.lidar, scan, Config)
                except Exception as e:
                    print(f"우측면 판정 예외: {e}")

            # [DEBUG] 레이더 시각화 창 갱신 (전체 스캔 + 우측 감시구역 + 최근접 각도/거리 라벨)
            cv2.imshow('Lidar Radar', draw_radar(scan, Config))
            # [PARK-US] 초음파 4개 실시간 디버그 창 갱신
            cv2.imshow('Ultrasonic Debug', draw_ultrasonic_debug(us_readings, Config))

            # 디바운스 카운터 갱신
            if occupied:
                occ_streak += 1
                empty_streak = 0
            else:
                empty_streak += 1
                occ_streak = 0

            # --- 미션 제한 시간 체크 (시작 이후에만) ---
            if state not in ('IDLE', 'DONE') and (now - mission_start) > Config.MISSION_TIMEOUT:
                print("[!] 미션 제한 시간(4분) 초과 → 정지")
                send_cmd(ser, "S\n")
                state = 'DONE'

            # --- 상태 머신 ---
            if not is_driving:
                # 🌟 [FIX] 토글로 정지된 상태: 어느 단계에 있든 정지 명령만 유지, 전환 판단은 모두 동결
                send_cmd(ser, "S\n")
            elif state == 'IDLE':
                send_cmd(ser, "S\n")

            elif state == 'SCAN_FIRST':
                # 직진 전진하며 첫 번째 주차 차량이 우측에 잡히길 기다림
                send_cmd(ser, f"A{Config.STEER_CENTER}\n")
                if occ_streak >= Config.DEBOUNCE_FRAMES:
                    seen_first_car = True
                    state = 'SCAN_GAP'
                    state_start = now
                    print(f"[1] 첫 차량 감지 (포인트 {n_pts}개) → 빈 칸 탐색 시작")

            elif state == 'SCAN_GAP':
                # 계속 전진하며 우측이 '비는' 순간(= 목표 주차 칸 시작)을 기다림
                send_cmd(ser, f"A{Config.STEER_CENTER}\n")
                if seen_first_car and empty_streak >= Config.DEBOUNCE_FRAMES:
                    state = 'ALIGN_FWD'
                    state_start = now
                    print("[2] 빈 칸 감지! 정렬 전진 시작")

            elif state == 'ALIGN_FWD':
                # 차체가 칸을 살짝 지나치도록 추가 전진
                send_cmd(ser, f"A{Config.STEER_CENTER}\n")
                if should_advance(state_start, now, Config.ALIGN_FWD_DURATION, key, "ALIGN_FWD", Config):
                    state = 'LEFT_FWD'
                    state_start = now
                    print("[3] 정렬 완료 → 좌로 꺾어 전진 시작")

            elif state == 'LEFT_FWD':
                # 좌로 꺾은 채 전진 → 후진 진입 각도 만들기
                send_cmd(ser, f"A{Config.STEER_MIN}\n")
                if should_advance(state_start, now, Config.LEFT_FWD_DURATION, key, "LEFT_FWD", Config):
                    # 후진 전, 우측 최대로 바퀴를 꺾어두고 모터는 일시정지시킵니다.
                    send_cmd(ser, f"B{Config.STEER_MAX}\n")
                    time.sleep(0.05)
                    send_cmd(ser, "S\n")
                    state = 'REV_RIGHT_PREP'
                    state_start = now
                    print("[3.5] 진입각 완료 → 우로 꺾고 후진 대기")

            elif state == 'REV_RIGHT_PREP':
                # 정지 상태를 유지하여 서보 모터가 완전히 후진 조향 바퀴를 꺾을 시간을 제공합니다.
                send_cmd(ser, "S\n")
                if should_advance(state_start, now, Config.REV_RIGHT_PREP_DURATION, key, "REV_RIGHT_PREP", Config):
                    state = 'REV_RIGHT'
                    state_start = now
                    print("[4] 후진 대기 완료 → 우로 꺾어 후진 진입")

            elif state == 'REV_RIGHT':
                # ⚠️ B 명령: 아두이노에 후진 처리가 추가되어 있어야 함
                # 후진과 동시에 조향이 우측 목표로 이동함
                send_cmd(ser, f"B{Config.STEER_MAX}\n")

                # [NEW] 뒤 모서리(CL, CR) 충돌 위험 실시간 감시 및 긴급 회피
                cl = us_readings.get('CL')
                cr = us_readings.get('CR')
                if cl is not None or cr is not None:
                    val_cl = cl if cl is not None else 999
                    val_cr = cr if cr is not None else 999
                    if (val_cl <= Config.CORNER_DANGER_CM or val_cr <= Config.CORNER_DANGER_CM) and adjust_count < Config.MAX_ADJUST_LIMIT:
                        adjust_count += 1
                        state = 'REV_STRAIGHT_ADJUST'
                        state_start = now
                        print(f"[4.2] 긴급! 뒤 모서리 충돌 위험 (CL:{cl}cm, CR:{cr}cm, 수정 {adjust_count}회차) → 회피 전진 시작")
                        continue

                if should_advance(state_start, now, Config.REV_RIGHT_DURATION, key, "REV_RIGHT", Config):
                    state = 'REV_STRAIGHT'
                    state_start = now
                    print("[5] 핸들 중앙, 직진 후진")

            elif state == 'REV_STRAIGHT':
                send_cmd(ser, f"B{Config.STEER_CENTER}\n")

                # [NEW] 뒤 모서리(CL, CR) 충돌 위험 실시간 감시 및 긴급 회피
                cl = us_readings.get('CL')
                cr = us_readings.get('CR')
                if cl is not None or cr is not None:
                    val_cl = cl if cl is not None else 999
                    val_cr = cr if cr is not None else 999
                    if (val_cl <= Config.CORNER_DANGER_CM or val_cr <= Config.CORNER_DANGER_CM) and adjust_count < Config.MAX_ADJUST_LIMIT:
                        adjust_count += 1
                        state = 'REV_STRAIGHT_ADJUST'
                        state_start = now
                        print(f"[5.1] 긴급! 뒤 모서리 충돌 위험 (CL:{cl}cm, CR:{cr}cm, 수정 {adjust_count}회차) → 회피 전진 시작")
                        continue

                # [FIX] 수정 주차를 반복할수록 누적되어 뒤로 밀려나는 현상 방지
                # - 최초 후진(adjust_count=0) 시에는 주차 칸 안으로 깊게 진입하도록 REV_STRAIGHT_DURATION(1.5초) 적용
                # - 수정 재후진(adjust_count>0) 시에는 전진했던 시간만큼만 제자리 복귀하도록 PARK_ADJUST_FWD_DURATION(1.2초) 동적 적용
                curr_duration = Config.REV_STRAIGHT_DURATION if adjust_count == 0 else Config.PARK_ADJUST_FWD_DURATION

                if should_advance(state_start, now, curr_duration, key, "REV_STRAIGHT", Config):
                    # 일자 후진 완료 직전 평행 오차를 확인합니다.
                    rf = us_readings.get('RF')
                    rr = us_readings.get('RR')
                    # 두 센서 거리가 정상적으로 들어왔고, 오차가 평행 임계치보다 크고, 아직 최대 조정 횟수에 도달하지 않았다면 수정 전진
                    if rf is not None and rr is not None and adjust_count < Config.MAX_ADJUST_LIMIT and abs(rf - rr) > Config.PARALLEL_DIFF_THRESHOLD_CM:
                        adjust_count += 1
                        state = 'REV_STRAIGHT_ADJUST'
                        state_start = now
                        print(f"[5.2] 삐딱함 감지 (차이 {abs(rf-rr)}cm, 수정 {adjust_count}회차) → 교정 전진 기동 시작")
                    else:
                        state = 'PARKED'
                        state_start = now
                        send_cmd(ser, "S\n")
                        print("[6] 주차 완료. 4초 정차 (규칙 3~5초)")

            elif state == 'REV_STRAIGHT_ADJUST':
                # 평행 보정 제어를 반영해 전진합니다.
                steer = get_parallel_steer(us_readings, Config)
                send_cmd(ser, f"A{steer}\n")
                if should_advance(state_start, now, Config.PARK_ADJUST_FWD_DURATION, key, "REV_STRAIGHT_ADJUST", Config):
                    # 재후진 전 모터를 정지하고 조향은 똑바로 펴줍니다.
                    send_cmd(ser, f"B{Config.STEER_CENTER}\n")
                    time.sleep(0.05)
                    send_cmd(ser, "S\n")
                    state = 'REV_STRAIGHT_PREP'
                    state_start = now
                    print("[5.4] 교정 전진 완료 → 재후진 전 정지 대기")

            elif state == 'REV_STRAIGHT_PREP':
                # 정지 상태를 대기하며 기어 역전 충격을 방지합니다.
                send_cmd(ser, "S\n")
                if should_advance(state_start, now, Config.REV_STRAIGHT_PREP_DURATION, key, "REV_STRAIGHT_PREP", Config):
                    state = 'REV_STRAIGHT'
                    state_start = now
                    print("[5.6] 정지 대기 완료 → 재후진(정렬) 시작")

            elif state == 'PARKED':
                send_cmd(ser, "S\n")
                # PARKED는 규칙상 3~5초 고정 정차이므로 단계 모드에서도 시간 기반 유지
                if (now - state_start) >= Config.PARKED_WAIT:
                    state = 'EXIT_FWD_PREP'
                    state_start = now
                    print("[6.5] 정차 해제 → 출차 직진 전진 시작")

            elif state == 'EXIT_FWD_PREP':
                # 핸들을 똑바로 정렬하고 전진 살짝
                send_cmd(ser, f"A{Config.STEER_CENTER}\n")
                if should_advance(state_start, now, Config.EXIT_FWD_PREP_DURATION, key, "EXIT_FWD_PREP", Config):
                    state = 'EXIT_TURN'
                    state_start = now
                    print("[7] 출차 준비 완료 → 전진 + 우회전 탈출")

            elif state == 'EXIT_TURN':
                # 후진 주차했으므로 차 머리는 통로 쪽 → 전진하며 우로 꺾어 OUT 방향으로
                send_cmd(ser, f"A{Config.STEER_MAX}\n")
                if should_advance(state_start, now, Config.EXIT_TURN_DURATION, key, "EXIT_TURN", Config):
                    state = 'EXIT_STRAIGHT'
                    state_start = now
                    print("[8] OUT 방향 직진")

            elif state == 'EXIT_STRAIGHT':
                send_cmd(ser, f"A{Config.STEER_CENTER}\n")
                if should_advance(state_start, now, Config.EXIT_STRAIGHT_DURATION, key, "EXIT_STRAIGHT", Config):
                    state = 'DONE'
                    send_cmd(ser, "S\n")
                    print("[9] 미션 종료 (OUT 라인 통과 목표). 정지.")

            elif state == 'DONE':
                send_cmd(ser, "S\n")

            # --- 상태 표시 ---
            canvas[:] = 0
            elapsed = (now - mission_start) if state not in ('IDLE',) and mission_start > 0 else 0.0
            label, motion, color = STATE_INFO.get(state, (state, "-", (255, 255, 255)))
            canvas = put_text_kr(canvas, f"[{state}] {label}", (10, 12), 22, (255, 255, 255))
            canvas = put_text_kr(canvas, motion, (10, 45), 32, color)

            # [NEW] 실시간 목표 조향각 및 아두이노 실제 피드백 조향각 오버레이
            target_ang = TARGET_ANGLE_BY_STATE.get(state, "-")
            if state == 'REV_STRAIGHT_ADJUST':
                target_ang = get_parallel_steer(us_readings, Config)
            ang_actual = current_angle_actual if current_angle_actual is not None else "-"
            canvas = put_text_kr(canvas, f"Target Steer: {target_ang}° | Actual: {ang_actual}°",
                                  (10, 85), 16, (0, 200, 255))

            canvas = put_text_kr(canvas, f"Right pts: {n_pts}  occ:{occ_streak} emp:{empty_streak}",
                                  (10, 110), 18, (0, 255, 255))
            # [DEBUG] 가까운 순 상위 3개 포인트 표시 (각도/거리 다양하게 확인용)
            if right_pts is not None and len(right_pts) > 0:
                order = np.argsort(right_pts[:, 1])[:3]
                top_line = "  ".join(
                    f"{right_pts[i, 0]:.0f}°/{right_pts[i, 1]:.0f}mm" for i in order
                )
                lidar_line = f"근접 top3: {top_line}"
                lidar_color = (0, 255, 255)
            else:
                lidar_line = "근접 top3: 감지 없음"
                lidar_color = (120, 120, 120)
            canvas = put_text_kr(canvas, lidar_line, (10, 138), 18, lidar_color)
            canvas = put_text_kr(canvas, f"Mission time: {elapsed:.1f}s / {Config.MISSION_TIMEOUT:.0f}s",
                                  (10, 168), 20, (255, 255, 255))
            step_hint = "  [n] next step" if Config.DEBUG_STEP_MODE else ""
            s_hint = "[s] start" if state == 'IDLE' else "[s] pause/resume"
            pause_tag = "  ⏸ PAUSED" if (state not in ('IDLE', 'DONE') and not is_driving) else ""
            canvas = put_text_kr(canvas, f"{s_hint}  [q] quit{step_hint}{pause_tag}",
                                  (10, 200), 18, (200, 200, 200))
            cv2.imshow('Parking Status', canvas)

            # [DEBUG] key는 루프 상단에서 이미 읽음 (waitKey 중복 호출 제거)
            if key == ord('q'):
                print("프로그램 종료.")
                break
            elif key == ord('s'):
                if state == 'IDLE':
                    # 최초 시작
                    is_driving = True
                    state = 'SCAN_FIRST'
                    mission_start = now
                    state_start = now
                    occ_streak = 0
                    empty_streak = 0
                    seen_first_car = False
                    adjust_count = 0  # 수정 기동 횟수 카운터 리셋
                    print("==== 🚗 주차 미션 시작! ====")
                elif state != 'DONE':
                    # 🌟 [FIX] 원본 주행코드처럼 토글: 미션 진행 중 s를 또 누르면 정지/재개
                    is_driving = not is_driving
                    if not is_driving:
                        pause_started_at = now
                        print("==== ⏸ 일시정지 (정지 명령 유지) ====")
                    else:
                        if pause_started_at is not None:
                            # 정지해 있던 시간만큼 이 상태의 지속시간 판단 기준을 뒤로 밀어줌
                            # (미션 전체 제한시간(mission_start)은 보정하지 않음 — 실제 경기 시계는 계속 흐름)
                            paused_for = now - pause_started_at
                            state_start += paused_for
                            pause_started_at = None
                        print("==== ▶ 재개 ====")

    except KeyboardInterrupt:
        print("\n사용자 강제 종료.")
    except Exception as e:
        print(f"\n에러 발생: {e}")
    finally:
        print("안전 종료 절차...")
        if ser is not None and ser.is_open:
            try:
                ser.write(b'S\n')
                time.sleep(0.1)
                ser.close()
                print("아두이노 포트 닫힘.")
            except Exception as e:
                print(f"아두이노 종료 에러: {e}")
        if lidar_stream is not None:
            lidar_stream.release()
        cv2.destroyAllWindows()


if __name__ == "__main__":
    main()
