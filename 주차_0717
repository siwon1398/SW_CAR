_RADAR_SIZE = 420
_RADAR_MAX_RANGE = 1500  # mm, 화면에 표시할 최대 거리 (이보다 먼 포인트는 가장자리에 clamp)


def _polar_to_xy(angle_deg, dist_mm, center, radius_px, max_range):
    # 화면 표시 규약: 0도를 12시 방향에 두고 시계방향으로 증가 (실제 회전방향과는 무관, 표시상의 약속)
    theta = np.radians(angle_deg - 90)
    r = min(dist_mm / max_range, 1.0) * radius_px
    x = int(center[0] + r * np.cos(theta))
    y = int(center[1] + r * np.sin(theta))
    return x, y


def draw_radar(scan, config):
    """라이다 전체 스캔을 원형 그래프로 그림. 정면(180도)과 우측 감시구역을 함께 표시.
    우측 감시구역 안에서 가장 가까운 포인트가 있으면, 그 옆에 각도/거리 숫자를 표시한다."""
    img = np.zeros((_RADAR_SIZE, _RADAR_SIZE, 3), dtype=np.uint8)
    center = (_RADAR_SIZE // 2, _RADAR_SIZE // 2)
    radius_px = _RADAR_SIZE // 2 - 55

    # 거리 참고선 (원 3개) + 각 원의 실제 거리(mm) 라벨
    # 라벨은 90도 방향(화면상 3시 방향, 정면선/감시구역과 안 겹치는 자리)에 배치
    for frac in (0.33, 0.66, 1.0):
        r = int(radius_px * frac)
        cv2.circle(img, center, r, (55, 55, 55), 1)
        lx, ly = _polar_to_xy(90, frac * _RADAR_MAX_RANGE, center, radius_px, _RADAR_MAX_RANGE)
        img = put_text_kr(img, f"{frac * _RADAR_MAX_RANGE:.0f}mm", (lx + 4, ly - 8), 12, (130, 130, 130))

    # [NEW] 원 바깥쪽에 45도 간격 각도 눈금
    for ang in range(0, 360, 45):
        theta = np.radians(ang - 90)
        tick_r = radius_px + 16
        tx = int(center[0] + tick_r * np.cos(theta))
        ty = int(center[1] + tick_r * np.sin(theta))
        # 텍스트가 화면 밖으로 안 나가도록 위치 보정 (대략적인 텍스트 폭/높이 감안)
        tx = min(max(tx - 14, 0), _RADAR_SIZE - 34)
        ty = min(max(ty - 8, 0), _RADAR_SIZE - 18)
        tick_color = (0, 90, 255) if ang == 180 else (150, 150, 150)  # 정면(180도)만 강조
        img = put_text_kr(img, f"{ang}°", (tx, ty), 13, tick_color)

    # 우측 감시구역 부채꼴 (반투명하게 보이도록 얇은 선으로 경계만 표시)
    zone_pts = [center]
    for a in np.linspace(config.RIGHT_SIDE_MIN_ANGLE, config.RIGHT_SIDE_MAX_ANGLE, 20):
        zone_pts.append(_polar_to_xy(a, _RADAR_MAX_RANGE, center, radius_px, _RADAR_MAX_RANGE))
    zone_pts = np.array(zone_pts, dtype=np.int32)
    overlay = img.copy()
    cv2.fillPoly(overlay, [zone_pts], (0, 70, 110))
    img = cv2.addWeighted(overlay, 0.4, img, 0.6, 0)

    # 정면(180도) 기준선 — 확인된 사실
    fx, fy = _polar_to_xy(180, _RADAR_MAX_RANGE, center, radius_px, _RADAR_MAX_RANGE)
    cv2.line(img, center, (fx, fy), (0, 90, 255), 2)

    # 차량 위치(중심) 표시
    cv2.circle(img, center, 5, (255, 255, 255), -1)

    # 스캔 포인트 찍기 + 감시구역 안 최근접 포인트 추적
    closest_zone_pt = None  # (x, y, angle, dist)
    if scan is not None:
        pts = np.array(scan)
        if len(pts) > 0:
            for angle, dist in pts:
                if dist <= 0:
                    continue
                in_zone = config.RIGHT_SIDE_MIN_ANGLE <= angle <= config.RIGHT_SIDE_MAX_ANGLE
                in_dist = config.RIGHT_SIDE_MIN_DIST <= dist <= config.RIGHT_SIDE_MAX_DIST
                if in_zone and in_dist:
                    color = (0, 165, 255)  # 우측 감시구역 + 거리조건까지 만족 (실제 판정에 쓰이는 포인트)
                elif in_zone:
                    color = (0, 255, 255)  # 각도는 구역 안이지만 거리조건 밖 (너무 가깝거나 멂)
                else:
                    color = (0, 200, 0)    # 구역 밖
                x, y = _polar_to_xy(angle, dist, center, radius_px, _RADAR_MAX_RANGE)
                cv2.circle(img, (x, y), 2, color, -1)

                # [NEW] 판정에 실제로 쓰이는(주황) 포인트 중 최근접만 따로 기억
                if in_zone and in_dist:
                    if closest_zone_pt is None or dist < closest_zone_pt[3]:
                        closest_zone_pt = (x, y, angle, dist)

    # [NEW] 감시구역 최근접 포인트 각도/거리 숫자 표시
    if closest_zone_pt is not None:
        px, py, p_angle, p_dist = closest_zone_pt
        cv2.circle(img, (px, py), 5, (255, 255, 255), 1)  # 강조 테두리
        label_x = min(max(px + 8, 0), _RADAR_SIZE - 100)
        label_y = min(max(py - 8, 0), _RADAR_SIZE - 16)
        img = put_text_kr(img, f"{p_angle:.0f}° {p_dist:.0f}mm", (label_x, label_y), 15, (255, 255, 255))

    # 라벨 (정면 각도 라벨은 위쪽 각도 눈금에서 이미 강조 표시되므로 화살표 옆 중복 라벨은 생략)
    img = put_text_kr(img, f"우측감시 {config.RIGHT_SIDE_MIN_ANGLE}~{config.RIGHT_SIDE_MAX_ANGLE}°",
                       (5, _RADAR_SIZE - 40), 14, (0, 165, 255))
    img = put_text_kr(img, f"표시 최대거리 {_RADAR_MAX_RANGE}mm", (5, _RADAR_SIZE - 20), 13, (150, 150, 150))
    return img


# ==========================================
# [PARK-US] 초음파 4개 실시간 디버그 시각화 (차량 상단뷰)
# ==========================================
_US_CANVAS_W, _US_CANVAS_H = 480, 340
_US_SCALE_PX_PER_CM = 2.2   # 거리 → 선 길이 변환 배율 (화면 표시용 스케일, 실측 검증 안 됨)
_US_MAX_LINE_CM = 120       # 이보다 먼 거리는 선 길이를 이 값으로 고정(clamp), 숫자 자체는 실측값 그대로 표시

# 차체 사각형 (앞이 위, 뒤가 아래)
_US_CAR_LEFT, _US_CAR_RIGHT = 170, 260
_US_CAR_TOP, _US_CAR_BOTTOM = 40, 260

# 센서 위치 및 뻗어나가는 방향(단위 벡터)
_US_SENSOR_LAYOUT = {
    'RF': {'pos': (_US_CAR_RIGHT, 100), 'dir': (1.0, 0.0),   'label': '우측앞(RF)'},
    'RR': {'pos': (_US_CAR_RIGHT, 200), 'dir': (1.0, 0.0),   'label': '우측뒤(RR)'},
    'CL': {'pos': (_US_CAR_LEFT, _US_CAR_BOTTOM), 'dir': (-0.7, 0.7), 'label': '왼쪽모서리(CL)'},
    'CR': {'pos': (_US_CAR_RIGHT, _US_CAR_BOTTOM), 'dir': (0.7, 0.7), 'label': '오른쪽모서리(CR)'},
}


def draw_ultrasonic_debug(us_readings, config):
    """차량을 위에서 본 모양에 초음파 4개의 현재 거리를 선/숫자로 실시간 표시.
    RF/RR(우측 앞뒤)는 평행 확인용, CL/CR(뒤 모서리)은 위험거리 경고용.
    자동 보정은 없고 표시만 한다."""
    img = np.zeros((_US_CANVAS_H, _US_CANVAS_W, 3), dtype=np.uint8)

    # 차체 윤곽
    cv2.rectangle(img, (_US_CAR_LEFT, _US_CAR_TOP), (_US_CAR_RIGHT, _US_CAR_BOTTOM), (90, 90, 90), 2)
    img = put_text_kr(img, "앞", (_US_CAR_LEFT + 35, _US_CAR_TOP - 24), 14, (150, 150, 150))
    img = put_text_kr(img, "뒤", (_US_CAR_LEFT + 35, _US_CAR_BOTTOM + 4), 14, (150, 150, 150))

    for key, layout in _US_SENSOR_LAYOUT.items():
        pos = layout['pos']
        dx, dy = layout['dir']
        dist_cm = us_readings.get(key)
        cv2.circle(img, pos, 4, (255, 255, 255), -1)

        is_corner = key in ('CL', 'CR')
        danger = is_corner and dist_cm is not None and dist_cm <= config.CORNER_DANGER_CM

        if dist_cm is None:
            line_color = (100, 100, 100)
            text = f"{layout['label']}: -"
            text_pos = (pos[0] + int(dx * 20) - (60 if dx < 0 else 0),
                        pos[1] + int(dy * 20))
        else:
            clamped = min(dist_cm, _US_MAX_LINE_CM)
            length_px = clamped * _US_SCALE_PX_PER_CM
            end = (int(pos[0] + dx * length_px), int(pos[1] + dy * length_px))
            line_color = (0, 0, 255) if danger else (0, 255, 0)
            cv2.line(img, pos, end, line_color, 2)
            cv2.circle(img, end, 4, line_color, -1)
            warn = "  ⚠" if danger else ""
            text = f"{layout['label']}: {dist_cm}cm{warn}"
            text_pos = (end[0] + (5 if dx >= 0 else -110),
                        end[1] - 10)

        text_pos = (min(max(text_pos[0], 0), _US_CANVAS_W - 130),
                    min(max(text_pos[1], 0), _US_CANVAS_H - 40))
        img = put_text_kr(img, text, text_pos, 14, line_color if dist_cm is not None else (150, 150, 150))

    # 평행 확인 요약 (우측 앞/뒤 차이)
    rf, rr = us_readings.get('RF'), us_readings.get('RR')
    if rf is not None and rr is not None:
        diff = abs(rf - rr)
        is_parallel = diff <= config.PARALLEL_DIFF_THRESHOLD_CM
        summary = f"평행확인: 앞{rf}cm 뒤{rr}cm 차이{diff}cm {'(평행)' if is_parallel else '(비평행)'}"
        summary_color = (0, 255, 0) if is_parallel else (0, 165, 255)
    else:
        summary = f"평행확인: 앞{rf if rf is not None else '-'}cm 뒤{rr if rr is not None else '-'}cm"
        summary_color = (120, 120, 120)
    img = put_text_kr(img, summary, (10, _US_CANVAS_H - 55), 15, summary_color)

    # 모서리 위험 요약
    cl, cr = us_readings.get('CL'), us_readings.get('CR')
    cl_danger = cl is not None and cl <= config.CORNER_DANGER_CM
    cr_danger = cr is not None and cr <= config.CORNER_DANGER_CM
    corner_summary = f"모서리: 좌{cl if cl is not None else '-'}cm 우{cr if cr is not None else '-'}cm"
    if cl_danger or cr_danger:
        corner_summary += "  ⚠ 위험"
        corner_color = (0, 0, 255)
    else:
        corner_color = (0, 255, 0) if (cl is not None or cr is not None) else (120, 120, 120)
    img = put_text_kr(img, corner_summary, (10, _US_CANVAS_H - 30), 15, corner_color)

    return img


