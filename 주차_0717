# [DEBUG] 한글 폰트 로드 (cv2.putText는 한글 미지원 → PIL로 대체)
# ==========================================
_KR_FONT_CANDIDATES = [
    "C:/Windows/Fonts/malgun.ttf",   # 맑은 고딕 (Windows 기본, 가장 흔함)
    "C:/Windows/Fonts/malgunbd.ttf",
    "C:/Windows/Fonts/gulim.ttc",
    "/usr/share/fonts/truetype/nanum/NanumGothic.ttf",  # 혹시 리눅스 환경일 경우
]
_kr_font_cache = {}


def _get_kr_font(size):
    if size in _kr_font_cache:
        return _kr_font_cache[size]
    for path in _KR_FONT_CANDIDATES:
        try:
            font = ImageFont.truetype(path, size)
            _kr_font_cache[size] = font
            return font
        except OSError:
            continue
    # 한글 폰트를 하나도 못 찾은 경우 (실행 시 한 번만 경고 출력)
    if size not in _kr_font_cache:
        print("[DEBUG] 한글 폰트를 찾지 못했습니다. 화면에 한글이 깨질 수 있습니다. "
              "(C:/Windows/Fonts 경로에 malgun.ttf가 있는지 확인)")
    font = ImageFont.load_default()
    _kr_font_cache[size] = font
    return font


def put_text_kr(canvas_bgr, text, org, size, color_bgr):
    """cv2.putText 대체: 한글이 포함된 문자열도 정상 렌더링."""
    img_pil = Image.fromarray(cv2.cvtColor(canvas_bgr, cv2.COLOR_BGR2RGB))
    draw = ImageDraw.Draw(img_pil)
    font = _get_kr_font(size)
    color_rgb = (color_bgr[2], color_bgr[1], color_bgr[0])
    draw.text(org, text, font=font, fill=color_rgb)
    return cv2.cvtColor(np.array(img_pil), cv2.COLOR_RGB2BGR)


