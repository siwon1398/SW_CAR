# [DEBUG/PARK-US] 아두이노 시리얼 데이터 일괄 읽기 (조향각 및 초음파)
# ==========================================
def read_serial_data(ser, last_angle, last_us, last_calib_l, last_calib_r, last_pot):
    """
    아두이노 시리얼 버퍼에서 들어오는 모든 라인을 소비하며 조향각, 초음파, 가변저항 데이터를 일괄 업데이트.
    """
    if ser is None or not ser.is_open:
        return last_angle, last_us, last_calib_l, last_calib_r, last_pot
    latest_angle = last_angle
    latest_us = dict(last_us)
    latest_calib_l = last_calib_l
    latest_calib_r = last_calib_r
    latest_pot = last_pot
    try:
        while ser.in_waiting > 0:
            line = ser.readline().decode('utf-8', errors='ignore').strip()
            if not line:
                continue
            # 1. 캘리브레이션 값 파싱
            if "Calib Left:" in line:
                try:
                    latest_calib_l = int(line.split("Calib Left:")[1].strip())
                except ValueError:
                    pass
            elif "Calib Right:" in line:
                try:
                    latest_calib_r = int(line.split("Calib Right:")[1].strip())
                except ValueError:
                    pass
            # 2. 실시간 Pot 및 각도 파싱
            elif "Pot:" in line:
                try:
                    parts = line.split("|")
                    latest_pot = int(parts[0].split("Pot:")[1].strip())
                    if "Cur Ang:" in parts[1]:
                        latest_angle = int(parts[1].split("Cur Ang:")[1].strip())
                except (ValueError, IndexError):
                    pass
            # 3. 초음파 거리 응답 처리 (US: RF=120 RR=118 CL=45 CR=200 형식)
            elif line.startswith("US:"):
                try:
                    parts = line[3:].strip().split()
                    parsed = {}
                    for p in parts:
                        key, val = p.split('=')
                        val = int(val)
                        parsed[key] = None if val < 0 else val
                    latest_us.update(parsed)
                except (ValueError, IndexError):
                    pass
    except Exception:
        pass
    return latest_angle, latest_us, latest_calib_l, latest_calib_r, latest_pot




