# [PARK] 우측면 차량 존재 여부 판단

def right_side_occupied(lidar_obj, scan, config): #오른쪽에 있는지 확인하는 함수
    """우측면 각도/거리 범위 안의 포인트 수로 차량 존재를 판단.
    반환: (있음 여부, 포인트 개수, 최근접 포인트 각도, 최근접 포인트 거리mm, 필터링된 포인트 배열)
    최근접 포인트가 없으면 각도/거리는 None."""
    pts = lidar_obj.getAngleDistanceRange(
        scan,
        config.RIGHT_SIDE_MIN_ANGLE, config.RIGHT_SIDE_MAX_ANGLE,
        config.RIGHT_SIDE_MIN_DIST, config.RIGHT_SIDE_MAX_DIST
    )
    if len(pts) > 0:
        closest_idx = np.argmin(pts[:, 1])
        closest_angle = float(pts[closest_idx, 0])
        closest_dist = float(pts[closest_idx, 1])
    else:
        closest_angle, closest_dist = None, None
    return len(pts) >= config.RIGHT_OCC_MIN_POINTS, len(pts), closest_angle, closest_dist, pts


# 중복 명령 전송 방지 및 유실 복구용 전역 변수
last_sent_cmd = ""
last_sent_time = 0.0

def send_cmd(ser, cmd): #cmd를 보내는함수
    global last_sent_cmd, last_sent_time
    if ser is not None and ser.is_open:
        now = time.time()
        # 동일한 명령이면서 마지막 송신 후 300ms(0.30초)가 지나지 않았다면 송신을 스킵합니다.
        # (유실 복구 및 상태 동기화를 위해 300ms마다 주기적으로 재송신 실행)
        if cmd == last_sent_cmd and (now - last_sent_time) < 0.30:
            return
        ser.write(cmd.encode('utf-8'))
        ser.flush()  # OS 버퍼를 비우고 아두이노로 즉각 물리적 송신 보장
        last_sent_cmd = cmd
        last_sent_time = now


