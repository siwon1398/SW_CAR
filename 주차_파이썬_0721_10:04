# [PARK-US] 전진 거리 유지 주행 (Wall/Car Following) 조향각 연산 함수
# ==========================================
def get_wall_following_steer(us_readings, config):
    # 옆차와 거리로 중앙에 들어가게 하면서 평행도 위와같은 방식으로 맞추는 함수
    rf = us_readings.get('RF')
    rr = us_readings.get('RR')
    if rf is not None and rr is not None:
        current_dist = (rf + rr) / 2.0
        dist_error = current_dist - config.DESIRED_WALL_DIST_CM
        angle_error = rf - rr

        # 거리 오차 보정 조향 + 평행 오차 보정 조향 결합
        steer_offset = int((dist_error * config.WALL_DIST_KP) + (angle_error * config.PARALLEL_KP))
        target_steer = config.STEER_CENTER + steer_offset
        return max(min(target_steer, config.STEER_MAX), config.STEER_MIN)
    return config.STEER_CENTER


