# [PARK-LIDAR-STOP] 라이다 기반 좌우 양옆 차량 감지 후진 자동정지 판정 함수
# ==========================================
def should_stop_by_lidar_both_sides(scan, config):
    """
    라이다 데이터를 이용하여 차량의 좌측(75~95도) 및 우측(265~285도) 양쪽에
    지정된 거리(LIDAR_STOP_MAX_DIST) 이내로 차량 모서리가 동시에 포착되는지 감지합니다.
    """
    if scan is None:
        return False
    pts = np.array(scan)
    if len(pts) == 0:
        return False

    # 1. 우측 차량 감지 검사 (265~285도)
    r_cond = np.where(
        (pts[:, 0] >= config.LIDAR_STOP_MIN_ANGLE_R) &
        (pts[:, 0] <= config.LIDAR_STOP_MAX_ANGLE_R) &
        (pts[:, 1] >= 150) &  # 초근접 노이즈 제외
        (pts[:, 1] <= config.LIDAR_STOP_MAX_DIST)
    )
    # 2. 좌측 차량 감지 검사 (75~95도)
    l_cond = np.where(
        (pts[:, 0] >= config.LIDAR_STOP_MIN_ANGLE_L) &
        (pts[:, 0] <= config.LIDAR_STOP_MAX_ANGLE_L) &
        (pts[:, 1] >= 150) &  # 초근접 노이즈 제외
        (pts[:, 1] <= config.LIDAR_STOP_MAX_DIST)
    )

    return len(pts[r_cond]) >= config.LIDAR_STOP_MIN_POINTS and len(pts[l_cond]) >= config.LIDAR_STOP_MIN_POINTS


